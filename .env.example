# ============================================
# Переменные окружения для проекта
# Скопируйте этот файл в .env и заполните своими данными
# ============================================

# Секретный ключ для Flask (придумайте любую случайную строку)
SECRET_KEY=ваш-секретный-ключ-здесь

# Подключение к базе данных PostgreSQL
# Формат: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bora_climate

# Настройки почты (для отправки писем, если понадобится)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
