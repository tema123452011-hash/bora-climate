# ============================================
# Dockerfile для BORA Climate
# Flask-приложение с PostgreSQL
# ============================================

# Используем официальный образ Python
FROM python:3.12-slim

# ============================================
# Настройка рабочей директории
# ============================================
WORKDIR /app

# ============================================
# Установка системных зависимостей
# Нужно для psycopg2 (подключение к PostgreSQL)
# ============================================
RUN apt-get update && apt-get install -y \
    gcc \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# ============================================
# Копирование зависимостей
# ============================================
COPY requirements.txt .

# Установка Python-зависимостей (с увеличенным таймаутом)
RUN pip install --no-cache-dir --default-timeout=100 -r requirements.txt

# ============================================
# Копирование приложения
# ============================================
COPY . .

# ============================================
# Переменные окружения
# ============================================
ENV PYTHONUNBUFFERED=1
ENV FLASK_APP=app

# ============================================
# Порт для Flask
# ============================================
EXPOSE 5000

# ============================================
# Запуск приложения
# ============================================
CMD ["python", "-c", "from app import app; app.run(host='0.0.0.0', port=5000)"]
